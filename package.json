{
  "name": "storybook-addon-determinism",
  "version": "0.1.0",
  "description": "Storybook addon that seeds Math.random and crypto for deterministic stories, snapshots, and visual regression tests.",
  "keywords": [
    "storybook-addon",
    "determinism",
    "deterministic",
    "random",
    "seed",
    "prng",
    "crypto",
    "uuid",
    "vrt",
    "visual-regression"
  ],
  "license": "MIT",
  "author": "k35o <kosakanoki@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/k35o/storybook-addon-determinism.git"
  },
  "files": [
    "dist/**/*",
    "preview.js",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:watch": "vp pack --watch",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix",
    "test": "vitest run",
    "start": "run-p build:watch 'storybook --quiet'",
    "release": "pnpm run build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@k8o/oxc-config": "0.1.3",
    "@storybook/addon-docs": "next",
    "@storybook/addon-vitest": "next",
    "@storybook/react-vite": "next",
    "@types/node": "24.12.4",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.8",
    "npm-run-all2": "9.0.1",
    "playwright": "1.60.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "next",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plus": "0.1.23",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  },
  "overrides": {
    "storybook": "$storybook"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.1",
  "storybook": {
    "displayName": "Determinism",
    "icon": "https://raw.githubusercontent.com/k35o/storybook-addon-determinism/main/.github/icon.png"
  }
}
